---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-32 text-center">
    <div class="text-8xl mb-6">404</div>
    <h1 class="text-3xl font-bold mb-4 gradient-text">页面未找到</h1>
    <p class="mb-8" style="color: var(--text-secondary);">
      您要查找的页面不存在或已被移除。
    </p>
    <a href="/" class="btn-primary">返回首页</a>
  </div>
</BaseLayout>