---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { getAllResources } from '../utils/resource';

const query = Astro.url.searchParams.get('q') || '';
const allResources = getAllResources();
const results = query
  ? allResources.filter((r) => {
      const f = r.frontmatter;
      const s = query.toLowerCase();
      return (
        f.title.toLowerCase().includes(s) ||
        f.description.toLowerCase().includes(s) ||
        f.tags?.some((t) => t.toLowerCase().includes(s)) ||
        f.category.toLowerCase().includes(s)
      );
    })
  : allResources;
---

<BaseLayout title={query ? `搜索: ${query}` : '搜索资源'}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold tracking-tight mb-6">搜索资源</h1>
    <form action="/search" method="GET" class="mb-10">
      <div class="relative max-w-xl">
        <input
          type="text"
          name="q"
          value={query}
          placeholder="搜索资源标题、简介、标签..."
          class="w-full rounded-2xl border-2 px-5 py-3.5 pl-12 text-sm outline-none transition-all duration-200"
          style="background-color: var(--bg-card); border-color: var(--border-color); color: var(--text-primary);"
          onfocus="this.style.borderColor='var(--accent)'"
          onblur="this.style.borderColor='var(--border-color)'"
        />
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5" style="color: var(--text-tertiary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </form>
    <p class="mb-6 text-sm" style="color: var(--text-secondary);">
      共找到 {results.length} 个{query ? '相关' : ''}资源
    </p>
    {results.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {results.map((r) => <ResourceCard resource={r} />)}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-lg mb-2" style="color: var(--text-tertiary);">未找到相关资源</p>
        <p class="text-sm" style="color: var(--text-tertiary);">请尝试其他关键词</p>
      </div>
    )}
  </div>
</BaseLayout>