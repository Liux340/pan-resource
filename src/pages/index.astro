---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getCategories, getLatestResources, getHotResources, getRecommendedResources } from '../utils/resource';

const categories = getCategories();
const latestResources = getLatestResources(8);
const hotResources = getHotResources();
const recommendedResources = getRecommendedResources();

const totalResources = Object.keys(import.meta.glob('../content/resources/*.md', { eager: true })).length;
const totalCategories = categories.length;
---

<BaseLayout title="首页">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 opacity-30 dark:opacity-20" style="background: radial-gradient(ellipse at top, var(--accent) 0%, transparent 70%);"></div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 md:py-32 relative">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight mb-6">
          发现精品<span class="gradient-text">网盘资源</span>
        </h1>
        <p class="text-lg md:text-xl mb-8" style="color: var(--text-secondary);">
          汇聚全网优质资源，夸克/百度/迅雷网盘高速下载，一站式资源发现平台
        </p>
        <div class="max-w-xl mx-auto">
          <form action="/search" method="GET" class="relative">
            <input
              type="text"
              name="q"
              placeholder="搜索资源、教程、软件..."
              class="w-full rounded-2xl border-2 px-5 py-3.5 pl-12 text-sm outline-none transition-all duration-200"
              style="background-color: var(--bg-card); border-color: var(--border-color); color: var(--text-primary);"
              onfocus="this.style.borderColor='var(--accent)'"
              onblur="this.style.borderColor='var(--border-color)'"
            />
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5" style="color: var(--text-tertiary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </form>
        </div>
        <div class="mt-8 flex flex-wrap justify-center gap-6">
          <div class="text-center">
            <div class="text-2xl font-bold gradient-text">{totalResources}</div>
            <div class="text-sm" style="color: var(--text-tertiary);">资源总数</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold gradient-text">{totalCategories}</div>
            <div class="text-sm" style="color: var(--text-tertiary);">资源分类</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 热门分类 -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title">热门分类</h2>
      <a href="/category" class="btn-outline text-sm">查看全部</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {categories.slice(0, 10).map((cat) => <CategoryCard category={cat} />)}
    </div>
  </section>

  <!-- 最新资源 -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16" style="background-color: var(--bg-secondary);">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title">最新资源</h2>
      <a href="/?tab=latest" class="btn-outline text-sm">查看全部</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {latestResources.map((r) => <ResourceCard resource={r} />)}
    </div>
  </section>

  <!-- 推荐资源 -->
  {recommendedResources.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-title">推荐资源</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {recommendedResources.map((r) => <ResourceCard resource={r} />)}
      </div>
    </section>
  )}

  <!-- 热门资源 -->
  {hotResources.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16" style="background-color: var(--bg-secondary);">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-title">热门资源</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {hotResources.map((r) => <ResourceCard resource={r} />)}
      </div>
    </section>
  )}
</BaseLayout>